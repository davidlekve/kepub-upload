#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"

# ---------------------------------------------------------------------------
# Resolve paths
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
CONVERTERS_DIR="${KEPUB_UPLOAD_CONVERTERS_DIR:-$SCRIPT_DIR/converters}"

# ---------------------------------------------------------------------------
# Colors (disabled when not a TTY or --no-color)
# ---------------------------------------------------------------------------
NO_COLOR="${NO_COLOR:-}"

setup_colors() {
  if [[ -t 1 && -z "$NO_COLOR" ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    BOLD='\033[1m'
    DIM='\033[2m'
    NC='\033[0m'
  else
    RED='' GREEN='' YELLOW='' BLUE='' BOLD='' DIM='' NC=''
  fi
}
setup_colors

log_info()    { echo -e "${BLUE}>${NC} $1"; }
log_success() { echo -e "${GREEN}>${NC} $1"; }
log_warn()    { echo -e "${YELLOW}!${NC} $1"; }
log_error()   { echo -e "${RED}x${NC} $1" >&2; }

# ---------------------------------------------------------------------------
# Dependency checking with OS-aware install hints
# ---------------------------------------------------------------------------
detect_installer() {
  if command -v pacman &>/dev/null; then
    if command -v yay &>/dev/null; then echo "yay"
    elif command -v paru &>/dev/null; then echo "paru"
    else echo "pacman"
    fi
  elif command -v apt-get &>/dev/null; then echo "apt"
  elif command -v dnf &>/dev/null;     then echo "dnf"
  elif command -v brew &>/dev/null;    then echo "brew"
  elif command -v zypper &>/dev/null;  then echo "zypper"
  else echo "unknown"
  fi
}

# require_tool <command> <install_hints...>
# Each hint is "manager:command", e.g. "pacman:pacman -S rclone"
require_tool() {
  local tool="$1"; shift
  command -v "$tool" &>/dev/null && return 0

  log_error "Required tool not found: ${BOLD}$tool${NC}"

  local installer
  installer="$(detect_installer)"
  local matched=""

  for hint in "$@"; do
    local mgr="${hint%%:*}"
    local cmd="${hint#*:}"
    # Match installer, and treat yay/paru as interchangeable for AUR
    if [[ "$mgr" == "$installer" \
       || ( "$mgr" == "yay" && "$installer" == "paru" ) \
       || ( "$mgr" == "paru" && "$installer" == "yay" ) ]]; then
      matched="$cmd"
      break
    fi
  done

  if [[ -n "$matched" ]]; then
    log_info "Install: ${BOLD}$matched${NC}"
  elif [[ $# -gt 0 ]]; then
    log_info "Install options:"
    for hint in "$@"; do
      echo "  ${hint#*:}"
    done
  fi

  return 1
}

# ---------------------------------------------------------------------------
# Cleanup
# ---------------------------------------------------------------------------
TEMP_FILES=()

cleanup() {
  for f in "${TEMP_FILES[@]:-}"; do
    rm -f "$f" 2>/dev/null || true
  done
}
trap cleanup EXIT

# ---------------------------------------------------------------------------
# Load converters
# ---------------------------------------------------------------------------
declare -A FORMAT_MAP        # extension -> format name
declare -a FORMAT_LIST=()    # ordered list of format names
declare -A FORMAT_DESC=()    # format name -> description

load_converters() {
  if [[ ! -d "$CONVERTERS_DIR" ]]; then
    log_error "Converters directory not found: $CONVERTERS_DIR"
    exit 1
  fi

  if [[ -n "${KEPUB_UPLOAD_CONVERTERS_DIR:-}" ]]; then
    log_warn "Using custom converters directory: $CONVERTERS_DIR"
  fi

  local count=0
  for converter in "$CONVERTERS_DIR"/*.sh; do
    [[ -f "$converter" ]] || continue

    local name
    name="$(basename "$converter" .sh)"

    # Validate converter name
    if [[ ! "$name" =~ ^[a-z][a-z0-9_-]*$ ]]; then
      log_warn "Skipping converter with invalid name: $name"
      continue
    fi

    # Read metadata from comments
    local desc exts
    desc="$(grep -m1 '^# Description:' "$converter" | sed 's/^# Description:[[:space:]]*//')"
    exts="$(grep -m1 '^# Extensions:' "$converter" | sed 's/^# Extensions:[[:space:]]*//')"

    # shellcheck source=/dev/null
    source "$converter"

    # Verify the converter defines the required function
    if ! declare -f "convert_${name}" &>/dev/null; then
      log_warn "Skipping $converter: missing convert_${name}() function"
      continue
    fi

    FORMAT_LIST+=("$name")
    FORMAT_DESC["$name"]="${desc:-$name files}"

    # Map extensions to format name
    IFS=',' read -ra ext_arr <<< "$exts"
    for ext in "${ext_arr[@]}"; do
      ext="$(echo "$ext" | tr -d ' ')"
      FORMAT_MAP["$ext"]="$name"
    done

    count=$((count + 1))
  done

  if [[ $count -eq 0 ]]; then
    log_error "No converters found in $CONVERTERS_DIR"
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Format detection
# ---------------------------------------------------------------------------

# Sort extensions by length (longest first) so .kepub.epub matches before .epub
_sorted_extensions() {
  printf '%s\n' "${!FORMAT_MAP[@]}" | awk '{ print length, $0 }' | sort -rn | awk '{ print $2 }'
}

detect_format() {
  local file="$1"
  local lower
  lower="$(echo "$file" | tr '[:upper:]' '[:lower:]')"

  local ext
  while IFS= read -r ext; do
    if [[ "$lower" == *"$ext" ]]; then
      echo "${FORMAT_MAP[$ext]}"
      return
    fi
  done < <(_sorted_extensions)

  echo "unknown"
}

# Get the stem (filename without the format extension)
get_stem() {
  local file="$1"
  local lower
  lower="$(echo "$file" | tr '[:upper:]' '[:lower:]')"

  local ext
  while IFS= read -r ext; do
    if [[ "$lower" == *"$ext" ]]; then
      local ext_len=${#ext}
      echo "${file:0:${#file}-$ext_len}"
      return
    fi
  done < <(_sorted_extensions)

  # Fallback: strip last extension
  echo "${file%.*}"
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
  local exit_code="${1:-0}"
  echo -e "${BOLD}kepub-upload${NC} ${DIM}v${VERSION}${NC}

Convert ebooks to Kobo kepub format and upload to cloud storage.

${BOLD}USAGE${NC}
  kepub-upload [options] <file>

${BOLD}FORMATS${NC}"

  for name in "${FORMAT_LIST[@]}"; do
    printf "  %-14s %s\n" "$name" "${FORMAT_DESC[$name]}"
  done

  echo -e "
${BOLD}OPTIONS${NC}
  -r, --remote NAME    rclone remote name  [default: ${KEPUB_UPLOAD_REMOTE:-gdrive}]
  -p, --path PATH      remote directory    [default: ${KEPUB_UPLOAD_PATH:-Rakuten Kobo}]
  -k, --keep           keep converted files locally
  -n, --dry-run        convert but don't upload
      --no-color       disable colored output
      --list-formats   list supported formats
  -V, --version        show version
  -h, --help           show this help

${BOLD}CONFIGURATION${NC}
  Config file: \${XDG_CONFIG_HOME:-~/.config}/kepub-upload/config

  ${DIM}KEPUB_UPLOAD_REMOTE=gdrive${NC}
  ${DIM}KEPUB_UPLOAD_PATH=Rakuten Kobo${NC}

  Environment variables and CLI flags override the config file.

${BOLD}EXAMPLES${NC}
  kepub-upload novel.epub
  kepub-upload textbook.pdf
  kepub-upload -r dropbox -p Books novel.epub
  kepub-upload --dry-run --keep novel.pdf"
  exit "$exit_code"
}

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
load_config() {
  local config="${KEPUB_UPLOAD_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/kepub-upload/config}"
  [[ -f "$config" ]] || return 0

  # Reject world-writable config files
  local perms
  perms="$(stat -c '%a' "$config" 2>/dev/null || stat -f '%Lp' "$config" 2>/dev/null || echo "")"
  if [[ -n "$perms" && "${perms: -1}" =~ [2367] ]]; then
    log_error "Config file is world-writable, refusing to load: $config"
    exit 1
  fi

  # Only allow variable assignments and comments
  if grep -qvE '^\s*(#|$|[A-Za-z_][A-Za-z_0-9]*=)' "$config"; then
    log_error "Config file contains invalid lines (only KEY=value allowed): $config"
    exit 1
  fi

  # shellcheck source=/dev/null
  source "$config"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
  load_config

  # Apply defaults after config so config values take precedence
  KEPUB_UPLOAD_REMOTE="${KEPUB_UPLOAD_REMOTE:-gdrive}"
  KEPUB_UPLOAD_PATH="${KEPUB_UPLOAD_PATH:-Rakuten Kobo}"

  load_converters

  # --- Parse arguments ---
  local keep=false dry_run=false input_file=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -r|--remote)
        [[ $# -ge 2 ]] || { log_error "--remote requires an argument"; exit 2; }
        KEPUB_UPLOAD_REMOTE="$2"; shift 2
        ;;
      -p|--path)
        [[ $# -ge 2 ]] || { log_error "--path requires an argument"; exit 2; }
        KEPUB_UPLOAD_PATH="$2"; shift 2
        ;;
      -k|--keep)       keep=true; shift ;;
      -n|--dry-run)    dry_run=true; shift ;;
      --no-color)      NO_COLOR=1; setup_colors; shift ;;
      --list-formats)
        for name in "${FORMAT_LIST[@]}"; do
          printf "%-14s %s\n" "$name" "${FORMAT_DESC[$name]}"
        done
        exit 0
        ;;
      -V|--version)    echo "kepub-upload $VERSION"; exit 0 ;;
      -h|--help)       usage 0 ;;
      -*)              log_error "Unknown option: $1"; echo; usage 2 ;;
      *)
        if [[ -n "$input_file" ]]; then
          log_error "Only one input file supported"
          exit 2
        fi
        input_file="$1"; shift
        ;;
    esac
  done

  if [[ -z "$input_file" ]]; then
    usage 2
  fi

  # --- Validate input ---
  if [[ ! -f "$input_file" ]]; then
    log_error "File not found: $input_file"
    exit 1
  fi

  input_file="$(realpath "$input_file")"
  local basename dir format stem
  basename="$(basename "$input_file")"
  dir="$(dirname "$input_file")"
  format="$(detect_format "$basename")"
  stem="$(get_stem "$basename")"

  if [[ "$format" == "unknown" ]]; then
    log_error "Unsupported format: $basename"
    log_info "Supported formats: ${FORMAT_LIST[*]}"
    log_info "Run ${BOLD}kepub-upload --list-formats${NC} for details"
    exit 1
  fi

  log_info "Input: ${BOLD}$basename${NC} ($format)"

  # --- Check converter dependencies ---
  if declare -f "convert_${format}_check" &>/dev/null; then
    "convert_${format}_check" || exit 1
  fi

  # Always need rclone for upload (unless dry-run)
  if [[ "$dry_run" == "false" ]]; then
    require_tool rclone \
      "pacman:pacman -S rclone" \
      "apt:sudo apt install rclone" \
      "brew:brew install rclone" \
      "dnf:sudo dnf install rclone" || exit 1
  fi

  # --- Convert ---
  KEPUB_FILE=""
  "convert_${format}" "$input_file" "$dir" "$stem"

  if [[ -z "$KEPUB_FILE" || ! -f "$KEPUB_FILE" ]]; then
    log_error "Conversion failed"
    exit 1
  fi

  # Track temp files for cleanup
  if [[ "$keep" == "false" && "$KEPUB_FILE" != "$input_file" ]]; then
    TEMP_FILES+=("$KEPUB_FILE")
  fi

  # --- Upload ---
  local dest="${KEPUB_UPLOAD_REMOTE}:${KEPUB_UPLOAD_PATH}"
  local kepub_basename
  kepub_basename="$(basename "$KEPUB_FILE")"

  if [[ "$dry_run" == "true" ]]; then
    log_warn "Dry run — skipping upload"
    log_info "Would upload: $kepub_basename"
    log_info "Destination:  $dest/"
    if [[ "$keep" == "true" ]]; then
      TEMP_FILES=()
    fi
    exit 0
  fi

  log_info "Uploading to ${BOLD}$dest/${NC}..."
  if ! rclone copy "$KEPUB_FILE" "$dest/" --progress 2>&1; then
    log_error "Upload failed"
    if ! rclone listremotes 2>/dev/null | grep -q "^${KEPUB_UPLOAD_REMOTE}:$"; then
      log_error "rclone remote ${BOLD}${KEPUB_UPLOAD_REMOTE}${NC} is not configured"
      log_info "Run ${BOLD}rclone config${NC} to set up a remote named ${BOLD}${KEPUB_UPLOAD_REMOTE}${NC}"
      log_info "Or specify a different remote: ${BOLD}kepub-upload -r <remote> <file>${NC}"
    fi
    exit 1
  fi

  # --- Summary ---
  echo
  log_success "Done!"
  if [[ "$keep" == "true" && "$KEPUB_FILE" != "$input_file" ]]; then
    echo -e "  ${BLUE}Local:${NC}  $KEPUB_FILE"
  fi
  echo -e "  ${BLUE}Remote:${NC} $dest/$kepub_basename"
}

main "$@"
